# LIGHTMAN CMS — Railway Deployment Variables
# Railway auto-injects DATABASE_URL when you add a PostgreSQL database.

# Server
NODE_ENV=production
PORT=3401
CORS_ORIGIN=*

# Authentication
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRY=24h

# Storage (local filesystem — works without S3 for demos)
STORAGE_PATH=./storage

# S3-compatible storage (optional — add Railway Buckets for persistent files)
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
